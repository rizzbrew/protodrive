{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "version": 2,
  "buildCommand": "bun run build",
  "outputDirectory": ".vercel/output",
  "rewrites": [
    {
      "source": "/api(/.*)?",
      "destination": "/api/index.js"
    },
    {
      "source": "/((?!api/|assets/|og-image.png|proto.svg).*)",
      "destination": "/index.html"
    }
  ]
}
